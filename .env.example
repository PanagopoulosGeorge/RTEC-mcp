# rtec_llm — example environment file.
# Copy to `.env` (gitignored) and fill in the providers you actually use.
# Adapters resolve their keys lazily; a missing key only breaks the adapter
# that asks for it, not the package.

# --- LLM providers --------------------------------------------------------
# OpenAI (primary per CLAUDE.md §6)
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# Ollama (local). Leave blank to use the default; override only if non-default.
OLLAMA_BASE_URL=http://localhost:11434

# --- Evaluation ------------------------------------------------------------
# LangSmith — datasets, traces, and evaluator runs (CLAUDE.md §6).
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=rtec-llm
