│                                                                                                                                                                                                                                   │
│  grounding(gap_start(V)) :- vessel(V).                                                                                                                                                                                            │
│  grounding(gap_end(V)) :- vessel(V).                                                                                                                                                                                              │
│  grounding(gap(V)=PortStatus) :- vessel(V), portStatus(PortStatus).                                                                                                                                                               │
